# JWT Secret Key - Change this to a secure random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/pcastpro

# Email Configuration for OTP (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-smtp-app-password
EMAIL_FROM="Ban Pick System <your-email@gmail.com>"

# Session Configuration
SESSION_TIMEOUT_HOURS=24

# OTP Configuration
OTP_EXPIRY_MINUTES=5

# Python Backend Configuration
PYTHON_BACKEND_URL=http://127.0.0.1:5000
USE_PYTHON_BACKEND=false
